# 复制为 application-local.yml 后按本机环境覆盖；真实 local 文件已被 Git 忽略。
# S1 不激活数据库、Redis、Sa-Token 或 Flyway，以下连接项从 S2 起使用。
spring:
  datasource:
    url: ${VIBE_DB_URL:jdbc:mysql://127.0.0.1:3306/vibe_boot?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai}
    username: ${VIBE_DB_USERNAME:vibe_boot}
    password: ${VIBE_DB_PASSWORD:}
  data:
    redis:
      host: ${VIBE_REDIS_HOST:127.0.0.1}
      port: ${VIBE_REDIS_PORT:6379}
      password: ${VIBE_REDIS_PASSWORD:}

server:
  address: ${VIBE_SERVER_ADDRESS:127.0.0.1}
  port: ${VIBE_SERVER_PORT:8080}

management:
  server:
    address: 127.0.0.1
    port: ${VIBE_MANAGEMENT_PORT:8081}
